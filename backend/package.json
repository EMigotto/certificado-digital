    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.1",
    "nodemailer": "^8.0.10",
    "papaparse": "^5.5.2",
    "pino": "^9.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.11",
    "@types/nodemailer": "^8.0.0",
