// Prisma schema for Certificado Digital
// Certificate inventory management system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CertStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  REVOKED
}

enum Environment {
  DEV
  HML
  PRD
}

enum ImportSource {
  MANUAL
  CSV_IMPORT
  API_SYNC
  CERTIFICATE_FILE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  REVOKE
  IMPORT
  EXPORT
}

enum AuditResult {
  SUCCESS
  FAILURE
}

// ---------------------------------------------------------------------------
// Certificate — core inventory entity (25+ fields)
// ---------------------------------------------------------------------------

model Certificate {
  id String @id @default(uuid())

  // ── Identity ──────────────────────────────────────────────────────────────
  commonName   String   @map("common_name")
  subjectDn    String?  @map("subject_dn")
  issuerDn     String?  @map("issuer_dn")
  sans         String[] @default([])
  serialNumber String   @map("serial_number")

  // ── Validity ──────────────────────────────────────────────────────────────
  notBefore DateTime   @map("not_before")
  notAfter  DateTime   @map("not_after")
  status    CertStatus @default(VALID)

  // ── Cryptography ──────────────────────────────────────────────────────────
  signatureAlgorithm String  @map("signature_algorithm")
  keySize            Int?    @map("key_size")
  fingerprintSha256  String  @unique @map("fingerprint_sha256")
  fingerprintSha1    String? @map("fingerprint_sha1")

  // ── Organization context ──────────────────────────────────────────────────
  owner       String
  team        String?
  application String
  environment Environment @default(DEV)
  zone        String?

  // ── CA / Provider ─────────────────────────────────────────────────────────
  caName     String  @map("ca_name")
  caProvider String? @map("ca_provider")

  // ── Import metadata ───────────────────────────────────────────────────────
  importSource ImportSource @default(MANUAL) @map("import_source")
  sourceFile   String?      @map("source_file")

  // ── Revocation ────────────────────────────────────────────────────────────
  revoked          Boolean   @default(false)
  revokedAt        DateTime? @map("revoked_at")
  revocationReason String?   @map("revocation_reason")

  // ── Flexible / custom fields ──────────────────────────────────────────────
  tags         Json    @default("{}") @db.JsonB
  customFields Json    @default("{}") @map("custom_fields") @db.JsonB
  description  String?

  // ── Raw PEM data (optional, for export) ───────────────────────────────────
  pemData String? @map("pem_data") @db.Text

  // ── System timestamps ─────────────────────────────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  auditEntries AuditEntry[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([notAfter], name: "idx_cert_not_after")
  @@index([status], name: "idx_cert_status")
  @@index([environment], name: "idx_cert_environment")
  @@index([caName], name: "idx_cert_ca_name")
  @@index([owner], name: "idx_cert_owner")
  @@index([commonName, issuerDn], name: "idx_cert_cn_issuer")
  @@map("certificates")
}

// ---------------------------------------------------------------------------
// CaConfig — Certificate Authority integration configuration
// ---------------------------------------------------------------------------

enum CaType {
  VAULT_PKI
  REST_CA
}

model CaConfig {
  id          String   @id @default(uuid())
  name        String   @unique
  type        CaType
  endpoint    String
  authToken   String?  @map("auth_token")
  authHeaders Json?    @map("auth_headers") @db.JsonB
  role        String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ca_configs")
}

// ---------------------------------------------------------------------------
// AuditEntry — immutable operation log
// ---------------------------------------------------------------------------

model AuditEntry {
  id String @id @default(uuid())

  // ── Certificate reference ─────────────────────────────────────────────────
  certificateId String?      @map("certificate_id")
  certificate   Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  certCn        String       @map("cert_cn")

  // ── Action details ────────────────────────────────────────────────────────
  action  AuditAction
  actor   String
  result  AuditResult @default(SUCCESS)
  detail  String?
  changes Json?       @db.JsonB
  batchId String?     @map("batch_id")

  // ── Timestamp (immutable) ─────────────────────────────────────────────────
  timestamp DateTime @default(now())

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([certificateId], name: "idx_audit_cert_id")
  @@index([action], name: "idx_audit_action")
  @@index([timestamp], name: "idx_audit_timestamp")
  @@index([actor], name: "idx_audit_actor")
  @@index([batchId], name: "idx_audit_batch_id")
  @@index([result], name: "idx_audit_result")
  @@map("audit_entries")
}
