// Prisma schema for Certificado Digital
// Certificate inventory management system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CertStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  REVOKED
}

enum Environment {
  DEV
  HML
  PRD
}

enum ImportSource {
  MANUAL
  CSV_IMPORT
  API_SYNC
  CERTIFICATE_FILE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  REVOKE
  IMPORT
  EXPORT
}

enum AuditResult {
  SUCCESS
  FAILURE
}

// ---------------------------------------------------------------------------
// Certificate — core inventory entity (25+ fields)
// ---------------------------------------------------------------------------

model Certificate {
  id String @id @default(uuid())

  // ── Identity ──────────────────────────────────────────────────────────────
  commonName   String   @map("common_name")
  subjectDn    String?  @map("subject_dn")
  issuerDn     String?  @map("issuer_dn")
  sans         String[] @default([])
  serialNumber String   @map("serial_number")

  // ── Validity ──────────────────────────────────────────────────────────────
  notBefore DateTime   @map("not_before")
  notAfter  DateTime   @map("not_after")
  status    CertStatus @default(VALID)

  // ── Cryptography ──────────────────────────────────────────────────────────
  signatureAlgorithm String  @map("signature_algorithm")
  keySize            Int?    @map("key_size")
  fingerprintSha256  String  @unique @map("fingerprint_sha256")
  fingerprintSha1    String? @map("fingerprint_sha1")

  // ── Organization context ──────────────────────────────────────────────────
  owner       String
  team        String?
  application String
  environment Environment @default(DEV)
  zone        String?

  // ── CA / Provider ─────────────────────────────────────────────────────────
  caName     String  @map("ca_name")
  caProvider String? @map("ca_provider")

  // ── Import metadata ───────────────────────────────────────────────────────
  importSource ImportSource @default(MANUAL) @map("import_source")
  sourceFile   String?      @map("source_file")

  // ── Revocation ────────────────────────────────────────────────────────────
  revoked          Boolean   @default(false)
  revokedAt        DateTime? @map("revoked_at")
  revocationReason String?   @map("revocation_reason")

  // ── Flexible / custom fields ──────────────────────────────────────────────
  tags         Json    @default("{}") @db.JsonB
  customFields Json    @default("{}") @map("custom_fields") @db.JsonB
  description  String?

  // ── Raw PEM data (optional, for export) ───────────────────────────────────
  pemData String? @map("pem_data") @db.Text

  // ── System timestamps ─────────────────────────────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  auditEntries     AuditEntry[]
  expirationAlerts ExpirationAlert[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([notAfter], name: "idx_cert_not_after")
  @@index([status], name: "idx_cert_status")
  @@index([environment], name: "idx_cert_environment")
  @@index([caName], name: "idx_cert_ca_name")
  @@index([owner], name: "idx_cert_owner")
  @@index([commonName, issuerDn], name: "idx_cert_cn_issuer")
  @@map("certificates")
}

// ---------------------------------------------------------------------------
// CaConfig — Certificate Authority integration configuration
// ---------------------------------------------------------------------------

enum CaType {
  VAULT_PKI
  REST_CA
}

model CaConfig {
  id          String   @id @default(uuid())
  name        String   @unique
  type        CaType
  endpoint    String
  authToken   String?  @map("auth_token")
  authHeaders Json?    @map("auth_headers") @db.JsonB
  role        String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ca_configs")
}

// ---------------------------------------------------------------------------
// AuditEntry — immutable operation log
// ---------------------------------------------------------------------------

model AuditEntry {
  id String @id @default(uuid())

  // ── Certificate reference ─────────────────────────────────────────────────
  certificateId String?      @map("certificate_id")
  certificate   Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  certCn        String       @map("cert_cn")

  // ── Action details ────────────────────────────────────────────────────────
  action  AuditAction
  actor   String
  result  AuditResult @default(SUCCESS)
  detail  String?
  changes Json?       @db.JsonB
  batchId String?     @map("batch_id")

  // ── Timestamp (immutable) ─────────────────────────────────────────────────
  timestamp DateTime @default(now())

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([certificateId], name: "idx_audit_cert_id")
  @@index([action], name: "idx_audit_action")
  @@index([timestamp], name: "idx_audit_timestamp")
  @@index([actor], name: "idx_audit_actor")
  @@index([batchId], name: "idx_audit_batch_id")
  @@index([result], name: "idx_audit_result")
  @@map("audit_entries")
}

// ---------------------------------------------------------------------------
// Expiration Monitoring — Enums
// ---------------------------------------------------------------------------

enum AlertStatus {
  PENDING
  NOTIFIED
  FAILED
  ACKNOWLEDGED
}

enum NotificationChannel {
  EMAIL
  WEBHOOK
}

enum NotificationStatus {
  SUCCESS
  FAILED
  SKIPPED
}

// ---------------------------------------------------------------------------
// ExpirationAlert — one record per certificate × threshold
// ---------------------------------------------------------------------------

model ExpirationAlert {
  id            String      @id @default(uuid())
  certificateId String      @map("certificate_id")
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  threshold     Int
  triggeredAt   DateTime    @map("triggered_at")
  status        AlertStatus @default(PENDING)

  // ── Certificate snapshot at alert time ────────────────────────────────────
  certificateCn          String   @map("certificate_cn")
  certificateSans        String[] @default([]) @map("certificate_sans")
  daysUntilExpiryAtAlert Int      @map("days_until_expiry_at_alert")
  caName                 String   @map("ca_name")
  owner                  String
  zone                   String?
  environment            String?

  // ── Acknowledgement ───────────────────────────────────────────────────────
  acknowledgedAt DateTime? @map("acknowledged_at")
  acknowledgedBy String?   @map("acknowledged_by")

  // ── System timestamps ─────────────────────────────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  notifications NotificationRecord[]

  // ── Constraints & Indexes ─────────────────────────────────────────────────
  @@unique([certificateId, threshold], name: "uq_alert_cert_threshold")
  @@index([status], name: "idx_alert_status")
  @@index([triggeredAt], name: "idx_alert_triggered_at")
  @@index([certificateId], name: "idx_alert_certificate_id")
  @@map("expiration_alerts")
}

// ---------------------------------------------------------------------------
// NotificationRecord — immutable log of each delivery attempt
// ---------------------------------------------------------------------------

model NotificationRecord {
  id            String              @id @default(uuid())
  alertId       String              @map("alert_id")
  alert         ExpirationAlert     @relation(fields: [alertId], references: [id], onDelete: Cascade)
  channel       NotificationChannel
  sentAt        DateTime            @map("sent_at")
  status        NotificationStatus
  errorMessage  String?             @map("error_message")
  webhookId     String?             @map("webhook_id")
  webhook       ExpirationWebhook?  @relation(fields: [webhookId], references: [id], onDelete: SetNull)
  attemptNumber Int                 @map("attempt_number")

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([alertId], name: "idx_notification_alert_id")
  @@index([channel], name: "idx_notification_channel")
  @@map("notification_records")
}

// ---------------------------------------------------------------------------
// ExpirationPolicy — configurable alert thresholds per zone
// ---------------------------------------------------------------------------

model ExpirationPolicy {
  id                        String   @id @default(uuid())
  name                      String
  description               String?
  zoneId                    String?  @map("zone_id")
  isDefault                 Boolean  @default(false) @map("is_default")
  thresholds                String   @db.Text
  emailEnabled              Boolean  @default(true) @map("email_enabled")
  emailRecipientsAdditional String?  @map("email_recipients_additional")
  emailSubjectPrefix        String?  @map("email_subject_prefix")
  createdBy                 String   @map("created_by")
  updatedBy                 String?  @map("updated_by")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  webhooks ExpirationWebhook[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  // Note: partial unique index (zone_id WHERE is_default = true) is added
  // in the raw SQL migration since Prisma does not support filtered indexes.
  @@map("expiration_policies")
}

// ---------------------------------------------------------------------------
// ExpirationWebhook — webhook endpoint config per policy
// ---------------------------------------------------------------------------

model ExpirationWebhook {
  id             String           @id @default(uuid())
  policyId       String           @map("policy_id")
  policy         ExpirationPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  url            String
  headers        Json             @default("{}") @db.JsonB
  retryStrategy  String?          @map("retry_strategy")
  maxRetries     Int              @default(3) @map("max_retries")
  timeoutSeconds Int              @default(30) @map("timeout_seconds")
  isActive       Boolean          @default(true) @map("is_active")
  testResult     String?          @map("test_result")
  lastTestAt     DateTime?        @map("last_test_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  notifications NotificationRecord[]

  // ── Indexes ───────────────────────────────────────────────────────────────
  @@index([policyId], name: "idx_webhook_policy_id")
  @@map("expiration_webhooks")
}

// ---------------------------------------------------------------------------
// ExpirationSnapshot — daily cached KPI + heatmap data
// ---------------------------------------------------------------------------

model ExpirationSnapshot {
  id                  String   @id @default(uuid())
  snapshotDate        DateTime @unique @map("snapshot_date") @db.Date
  totalManaged        Int      @map("total_managed")
  validCount          Int      @map("valid_count")
  expiringLessThan30d Int      @map("expiring_less_than_30d")
  expiredOrRevoked    Int      @map("expired_or_revoked")
  expirationsByDay    String   @map("expirations_by_day") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("expiration_snapshots")
}
