{
  "name": "certificado-digital",
  "version": "0.1.0",
  "private": true,
  "description": "mTLS Control Plane — Certificate Lifecycle Manager",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc",
    "build:frontend": "node scripts/build-frontend.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:all": "vitest run --coverage && playwright test",
    "lint": "echo 'no lint configured yet'"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node-forge": "^1.3.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.1",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
